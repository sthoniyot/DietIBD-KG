# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.env
.envrc

# Data (don't commit large files)
data/raw/*
data/processed/*
data/ontologies/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/ontologies/.gitkeep

# Logs
logs/*
!logs/.gitkeep

# IDE
.vscode/
.idea/
*.swp

# Notebooks
.ipynb_checkpoints/

# KG releases
kg_release/*.tar.gz
kg_release/*.zip

# Secrets
.env
*.key
api_keys.txt

# Exceptions: keep curated manual mapping tables in version control
!data/processed/manual_*.tsv
!data/processed/curated_*.tsv

# Exception: keep generated triples TSVs in version control (small, curated outputs)
!data/processed/triples_*.tsv

# Exception: FooDB curated mapping files (small, source-of-truth)
!data/processed/foodb_chebi_mapping.tsv
!data/processed/foodb_compound_allowlist.tsv

# Exception: Bolte 2021 food mapping table (curated, source-of-truth)
!data/processed/bolte_food_mappings.tsv

# Exception: FODMAP classification table (curated, source-of-truth)
!data/processed/fodmap_classifications.tsv

# Exception: Canonical reconciliation table (curated, source-of-truth)
!data/processed/canonical_id_map.tsv

# Exception: Gold-standard annotations (curated, source-of-truth)
!data/processed/gold_standard_annotations.tsv

# Exception: Gold-standard source abstract list (curated, source-of-truth)
!data/processed/gold_standard_to_annotate.tsv

# Exception: Phase C Stage 4 splits (deterministic, reproducible)
!data/processed/gold_split_dev.tsv
!data/processed/gold_split_test.tsv
!data/processed/gold_split_fewshot.tsv

# Exception: Phase C Stage 4 LLM extractions
!data/processed/llm_extractions/
!data/processed/llm_extractions/*.tsv

# Backup files and working scratch
.env.bak
abstracts_to_reannotate.txt
data/processed/embeddings/transe/
data/processed/embeddings/distmult/
data/processed/embeddings/rotate/
*.egg-info/
.pytest_cache/
/release/
backups/
typing_triage/

# --- v1.4.0: KEGG-derived data excluded (non-redistributable) ---
# Regenerate the pathway layer via src/ingestion/ingest_kegg_pathways.py
data/processed/triples_kegg.tsv
data/processed/kegg_chebi_mapping.tsv
data/processed/kegg_ibd_pathways.tsv

# Exception: consolidated v1.4.0 release graph (resource of record)
!data/processed/nodes_consolidated.tsv
!data/processed/edges_consolidated.tsv
